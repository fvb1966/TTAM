{
  "name": "ttam",
  "version": "0.1.0",
  "private": true,
  "description": "Table Tennis Academy Manager (TTAM) - Electron + Vite + React",
  "main": "src/main/main.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest"
  },
  "build": {
    "appId": "com.ttam.app",
    "productName": "TTAM",
    "files": [
      "dist/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.3.6",
    "react-hook-form": "^7.43.9",
    "zod": "^3.22.2",
    "@tanstack/react-table": "^8.8.2",
    "jspdf": "^2.5.1",
    "xlsx": "^0.18.5",
    "@prisma/client": "^5.13.0"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "vite": "^5.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.4.0",
    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.24",
    "autoprefixer": "^10.4.14",
    "prisma": "^5.13.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.1",
    "vitest": "^1.2.3",
    "esbuild": "^0.19.4",
    "eslint": "^8.45.0",
    "prettier": "^2.8.8",
    "eslint-config-prettier": "^9.2.0"
  }
}
