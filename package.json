{
  "name": "ttam",
  "version": "0.1.0",
  "private": true,
  "description": "Table Tennis Academy Manager (TTAM) - Electron + Vite + React",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx src --max-warnings 0",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.jsx src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --outfile=dist/main.js --external:electron --external:@aws-sdk/client-s3 --sourcemap && esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/preload.js --sourcemap",
    "dist": "electron-builder",
    "build:main:watch": "concurrently \"esbuild src/main/main.ts --bundle --platform=node --outfile=dist/main.js --external:electron --sourcemap --watch\" \"esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/preload.js --sourcemap --watch\"",
    "electron:dev": "concurrently \"npm:dev\" \"npm:build:main:watch\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest",
    "seed:admin": "node scripts/seed-admin.js",
    "smoke": "bash scripts/docker-smoke.sh"
  },
  "build": {
    "appId": "com.ttam.app",
    "productName": "TTAM",
    "npmRebuild": true,
    "files": [
      "dist/**",
      "package.json",
      "node_modules/**"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@tanstack/react-table": "^8.8.2",
    "archiver": "^8.0.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^1.21.0",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.9",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "unzipper": "^0.12.3",
    "xlsx": "^0.18.5",
    "zod": "^3.22.2",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^26.0.0",
    "electron-builder": "^24.4.0",
    "esbuild": "^0.19.4",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.1.6",
    "vite": "^5.2.0",
    "vitest": "^1.2.3",
    "@testing-library/react": "^14.0.0",
    "jsdom": "^22.1.0",
    "wait-on": "^7.0.1"
  }
  ,
  "vitest": {
    "test": {
      "environment": "jsdom"
    }
  }
}
